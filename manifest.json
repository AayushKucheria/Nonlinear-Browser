{
  "name": "Nonlinear Browser",
  "description": "Representing browser tabs in a tree for contextual thought",
  "version": "0.5.0",
  "permissions": ["tabs", "storage", "sidePanel", "bookmarks", "processes"],
  "host_permissions": ["file:///*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "res/logo/favicon.png",
    "default_title": "Open Nonlinear Browser"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "Toggle sidebar"
    },
    "focus-pin-1": { "suggested_key": { "default": "Ctrl+Shift+1", "mac": "Command+Shift+1" }, "description": "Switch to pinned tab 1" },
    "focus-pin-2": { "suggested_key": { "default": "Ctrl+Shift+2", "mac": "Command+Shift+2" }, "description": "Switch to pinned tab 2" },
    "focus-pin-3": { "suggested_key": { "default": "Ctrl+Shift+3", "mac": "Command+Shift+3" }, "description": "Switch to pinned tab 3" }
  },
  "manifest_version": 3,
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
